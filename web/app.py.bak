@app.patch("/cohort/{cid}/name", response_class=HTMLResponse)
async def cohort_name_update(cid: int, r: Request):
    redir = require_login(r)
    if redir:
        return redir
    f = await r.form()
    name = (f.get("name") or "").strip()
    if not name:
        return "<span class='text-red-400'>Cannot be empty</span>"
    user = get_user(r)
